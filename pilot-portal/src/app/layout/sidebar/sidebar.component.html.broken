        <svg class="w-5 h-5 text-slate-400 group-hover:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <span>ATPL</span>
      </a>
    </div>

    <!-- Profile -->
    <div class="mt-6">
      <a
        routerLink="/profile"
        routerLinkActive="bg-blue-600 text-white shadow-lg"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 dark:hover:bg-slate-800 transition-all group"
      >
        <svg class="w-5 h-5 text-slate-400 group-hover:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
