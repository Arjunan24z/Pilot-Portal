    <!-- Licenses Section -->
    <div class="mt-6">
      <p class="text-xs uppercase text-slate-500 dark:text-slate-600 font-semibold mb-2 px-3">Licenses & Ratings</p>

      <a routerLink="/license/spl" routerLinkActive="bg-blue-600 text-white shadow-lg"
