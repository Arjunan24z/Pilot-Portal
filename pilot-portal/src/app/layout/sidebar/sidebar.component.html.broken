      routerLinkActive="bg-blue-600 text-white shadow-lg"
      class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 dark:hover:bg-slate-800 transition-all group"
    >
      <svg class="w-5 h-5 text-slate-400 group-hover:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      <span>Dashboard</span>
    </a>

    <!-- Logbook Section -->
    <div class="mt-6">
      <p class="text-xs uppercase text-slate-500 dark:text-slate-600 font-semibold mb-2 px-3">Flight Operations</p>
      
      <a
        routerLink="/logbook"
        routerLinkActive="bg-blue-600 text-white shadow-lg"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 dark:hover:bg-slate-800 transition-all group"
      >
        <svg class="w-5 h-5 text-slate-400 group-hover:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span>Logbook</span>
        <span class="ml-auto text-xs bg-blue-500 text-white px-2 py-0.5 rounded-full">New</span>
      </a>
    </div>

    <!-- Medical Section -->
    <div class="mt-6">
      <p class="text-xs uppercase text-slate-500 dark:text-slate-600 font-semibold mb-2 px-3">Medical Certificates</p>

      <a
        routerLink="/medicals/class1"
        routerLinkActive="bg-blue-600 text-white shadow-lg"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 dark:hover:bg-slate-800 transition-all group"
      >
        <svg class="w-5 h-5 text-slate-400 group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Class 1</span>
      </a>

      <a
        routerLink="/medicals/class2"
        routerLinkActive="bg-blue-600 text-white shadow-lg"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-slate-800 dark:hover:bg-slate-800 transition-all group mt-1"
      >
        <svg class="w-5 h-5 text-slate-400 group-hover:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Class 2</span>
      </a>
    </div>
    </div>

    <!-- Licenses -->
